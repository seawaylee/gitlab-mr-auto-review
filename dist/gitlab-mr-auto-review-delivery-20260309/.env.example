# GitLab
GITLAB_URL=https://gitlab.example.com/
GITLAB_USERNAME=your_gitlab_username
GITLAB_PASSWORD=replace_with_real_password
GITLAB_SSL_VERIFY=false
# Prefer token auth in production
# GITLAB_PRIVATE_TOKEN=glpat-xxxxx
GITLAB_REVIEWER_USERNAME=your_gitlab_username
GITLAB_REVIEW_SCOPE=reviewer_or_assignee

# OpenAI (optional but recommended for better review quality)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1
# OPENAI_BASE_URL=

# Review backend: openclaw (recommended) | openai
REVIEW_PROVIDER=openclaw
OPENCLAW_REVIEW_AGENT=sohu
OPENCLAW_REVIEW_TIMEOUT_SECONDS=180
OPENCLAW_REVIEW_LOCAL=false
OPENCLAW_REVIEW_BIN=

# sohu push mode: openclaw (recommended) | webhook
SOHU_PUSH_MODE=openclaw

# OpenClaw route (when SOHU_PUSH_MODE=openclaw)
SOHU_OPENCLAW_BIN=
SOHU_OPENCLAW_CHANNEL=feishu
SOHU_OPENCLAW_ACCOUNT=sohu
# optional; if empty, auto-resolve from ~/.openclaw/agents/sohu/sessions/sessions.json
SOHU_OPENCLAW_TARGET=
# default false: send feishu doc link only; set true if you still need markdown attachment
SOHU_ATTACH_REPORT=false

# Webhook route (when SOHU_PUSH_MODE=webhook)
SOHU_AGENT_WEBHOOK_URL=

# Feishu app credentials and target receiver
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_RECEIVE_ID=
FEISHU_RECEIVE_ID_TYPE=open_id
FEISHU_BASE_URL=https://open.feishu.cn
# optional: create docs under specific folder
FEISHU_DOC_FOLDER_TOKEN=
# optional fallback link base, e.g. https://sohu.feishu.cn/docx
FEISHU_DOC_URL_BASE=

# Local paths
REPORT_DIR=reports
STATE_FILE=data/processed_mrs.json

# BTC monitor style runtime switch: dry-run means no external sends
DRY_RUN=false
